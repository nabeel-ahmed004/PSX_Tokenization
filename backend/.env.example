# ─────────────────────────────────────────────────────────
#  PSX Tokenization Platform — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit your real .env to Git.
# ─────────────────────────────────────────────────────────

# Your wallet private key (without 0x prefix)
# This is the deployer / admin wallet
PRIVATE_KEY=your_private_key_here

# Sepolia RPC URL — get a free one from Alchemy or Infura
# Alchemy:  https://dashboard.alchemy.com
# Infura:   https://infura.io
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_api_key_here

# Etherscan API key for contract verification (free at https://etherscan.io)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Set to "true" to enable gas cost reporting during tests
REPORT_GAS=false
